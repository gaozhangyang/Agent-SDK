    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python: recursive_survey_agent run.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/recursive_survey_agent/run.py",
            "cwd": "${workspaceFolder}/recursive_survey_agent",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}